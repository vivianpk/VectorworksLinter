
import vs

dialog_box       = None
BTN_OK          = 1
BTN_CANCEL      = 2
CB_MISSING_CH   = 5   # Missing Channels checkbox
CB_MISSING_NUM  = 6   # Missing Instrument Numbers checkbox
CB_DUP_ADDR     = 7   # Duplicate Addresses checkbox
LABEL_INTL_DUP  = 8
ET_INTL_DUP     = 9

channel_selected = True
instru_selected = True
address_selected = True
ignore_addr = []
 
 
def CreateDialog():
    global dialog_box
    dialog_box = vs.CreateResizableLayout('Checking For...', False,'OK','Cancel',True,True,)
    vs.CreateCheckBox(dialog_box, CB_MISSING_CH,  'Missing Channels')
    vs.CreateCheckBox(dialog_box, CB_MISSING_NUM, 'Missing Instrument Numbers')
    vs.CreateCheckBox(dialog_box, CB_DUP_ADDR,    'Duplicate Addresses')
    vs.CreateStaticText(dialog_box, LABEL_INTL_DUP, 'Intentional Duplicate Addresses (Absolute):', 40)
    vs.CreateEditText(dialog_box, ET_INTL_DUP, 'eg. 31,19,7', 30)

    vs.SetFirstLayoutItem(dialog_box, CB_MISSING_CH)
    vs.SetBelowItem(dialog_box, CB_MISSING_CH,  CB_MISSING_NUM, 0, 0)
    vs.SetBelowItem(dialog_box, CB_MISSING_NUM, CB_DUP_ADDR,    0, 0)
    vs.SetBelowItem(dialog_box, CB_DUP_ADDR,    LABEL_INTL_DUP, 0, 0)
    vs.SetRightItem(dialog_box, LABEL_INTL_DUP, ET_INTL_DUP,    0, 0)

    return dialog_box
 
 
def DialogHandler(item, data):
    global channel_selected, instru_selected, address_selected
    
    vs.EnableItem(dialog_box, LABEL_INTL_DUP, False)
    vs.EnableItem(dialog_box, ET_INTL_DUP, False)
    is_checked = vs.GetBooleanItem(dialog_box, CB_DUP_ADDR)
    if is_checked:
        vs.EnableItem(dialog_box, LABEL_INTL_DUP, True)
        vs.EnableItem(dialog_box, ET_INTL_DUP, True)
          
    if item == BTN_OK:
        channel_selected = vs.GetBooleanItem(dialog_box, CB_MISSING_CH)
        instru_selected = vs.GetBooleanItem(dialog_box, CB_MISSING_NUM)
        address_selected = vs.GetBooleanItem(dialog_box, CB_DUP_ADDR)
        if address_selected:
            raw = vs.GetItemText(dialog_box, ET_INTL_DUP)
            parse_intentional_duplicates(raw) #Turns a string of comma separated addresses into a list of strings of addresses

        RunChecks(channel_selected, instru_selected, address_selected)

def parse_intentional_duplicates(raw):
    global ignore_addr
    ignore_addr = []
    for part in raw.split(','):
        part = part.strip()
        ignore_addr.append(part)
    return ignore_addr
 
def CheckMissingChannels():
    results = []
 
    def visitor(h):
        if vs.GetTypeN(h) == 86:          # Type 86 indicates a Lighting Device
            channel = vs.GetRField(h, 'Lighting Device', 'Channel')
            if not channel or channel.strip() == '' or channel.strip() == '0':
                name = 'Position: ' + vs.GetRField(h, 'Lighting Device', 'Position') + '| Inst. Type: ' + vs.GetRField(h, 'Lighting Device', 'Inst Type') + '| Inst. Number: ' + vs.GetRField(h, 'Lighting Device', 'Unit Number')
                results.append(name)
 
    vs.ForEachObject(visitor, "((PON='Lighting Device'))") #Calls visitor function for every lighting device in the document
    return results
 
 
def CheckMissingInstrumentNumbers():
    results = []
 
    def visitor(h):
        if vs.GetTypeN(h) == 86:
            unit_num = vs.GetRField(h, 'Lighting Device', 'Unit Number')
            if not unit_num or unit_num.strip() == '':
                name = 'Position: ' + vs.GetRField(h, 'Lighting Device', 'Position') + '| Inst. Type: ' + vs.GetRField(h, 'Lighting Device', 'Inst Type') + '| Channel: ' + vs.GetRField(h, 'Lighting Device', 'Channel')
                results.append(name)
 
    vs.ForEachObject(visitor, "((PON='Lighting Device'))")
    return results
 
 
def CheckDuplicateAddresses():
    addr_list = []
    dup_addr_list = []
    results = []
    global ignore_addr
 
    def visitor(h):
        if vs.GetTypeN(h) == 86:
            absolute_address = vs.GetRField(h, 'Lighting Device', 'Absolute Address') 
            if absolute_address in addr_list: 
                if absolute_address not in ignore_addr: #If visitor has seen this address before and it isn't in the ignore list, it gets added to the duplicate list
                    dup_addr_list.append(absolute_address)
            else:
                addr_list.append(absolute_address)
    vs.ForEachObject(visitor, "((PON='Lighting Device'))")

    def comparator(h):
        if vs.GetTypeN(h) == 86:
            absolute_address = vs.GetRField(h, 'Lighting Device', 'Absolute Address')
            if absolute_address in dup_addr_list: #Any fixture with an address in the duplicate list gets added to the results list
                name = 'Position: ' + vs.GetRField(h, 'Lighting Device', 'Position') + '| Addr: ' + vs.GetRField(h, 'Lighting Device', 'Absolute Address') + '| Inst. Number: ' + vs.GetRField(h, 'Lighting Device', 'Unit Number')#name should be position, instrument type, instrument num
                results.append(name)
    vs.ForEachObject(comparator, "((PON='Lighting Device'))")
    
    return results

 
 
def RunChecks(do_channels, do_numbers, do_addresses):
    report_lines = []
 
    if not any([do_channels, do_numbers, do_addresses]):
        vs.AlrtDialog('No checks were selected.')
        return
 
    if do_channels:
        missing = CheckMissingChannels()
        if missing:
            report_lines.append(f'Missing Channels ({len(missing)}):') #number of fixtures missing a channel
            for name in missing:
                report_lines.append(f'  • {name}') #Identifier for fixtures missing a channel
        else:
            report_lines.append('Missing Channels: none found ✓')
        report_lines.append('\n')
 
    if do_numbers:
        missing = CheckMissingInstrumentNumbers()
        if missing:
            report_lines.append(f'Missing Instrument Numbers ({len(missing)}):')
            for name in missing:
                report_lines.append(f'  • {name}')
        else:
            report_lines.append('Missing Instrument Numbers: none found ✓')
        report_lines.append('\n')
 
    if do_addresses:
        dupes = CheckDuplicateAddresses()
        if dupes:
            report_lines.append(f'Duplicate Addresses ({len(dupes)} conflict(s)):')
            for name in dupes:
                report_lines.append(f'  • {name}')
        else:
            report_lines.append('Duplicate Addresses: none found ✓')
 
    vs.AlrtDialog('\n'.join(report_lines))
 
def Main():
    dialog_box = CreateDialog()
    result = vs.RunLayoutDialog(dialog_box, DialogHandler)
    if result != 1: #Closes dialog box if user selects 'Cancel'
        return
 
Main()
